datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          Role      @default(CLIENT)
  coachId       String?
  coach         User?     @relation("CoachToClients", fields: [coachId], references: [id], onDelete: Cascade)
  clients       User[]    @relation("CoachToClients")
  goals         Goals?
  meals         Meal[]
  routines      Routine[]
  weightLogs    WeightLog[]
  progressPhotos ProgressPhoto[]
  customMeals   MealTemplate[]
  coachSubscriptions ClientSubscription[] @relation("CoachSubscriptions")
  clientSubscriptions ClientSubscription[] @relation("ClientSubscriptions")
  coachAssignments Assignment[] @relation("CoachAssignments")
  clientAssignments Assignment[] @relation("ClientAssignments")
  coachChangeRequests ChangeRequest[] @relation("CoachChangeRequests")
  clientChangeRequests ChangeRequest[] @relation("ClientChangeRequests")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([coachId])
  @@index([email])
}

enum Role {
  COACH
  CLIENT
}

model Goals {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  calories  Int       @default(2000)
  protein   Int       @default(150)
  carbs     Int       @default(200)
  fat       Int       @default(65)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Food {
  id       String   @id @default(cuid())
  name     String   @unique
  kcal     Float
  protein  Float
  carbs    Float
  fat      Float
  portions     FoodPortion[]
  mealItems    MealTemplateItem[]
  createdAt DateTime @default(now())

  @@index([name])
}

model FoodPortion {
  id     String @id @default(cuid())
  foodId String
  food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)
  label  String
  grams  Float

  @@index([foodId])
}

model Meal {
  id          String   @id @default(cuid())
  clientId    String
  client      User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  mealDate    String
  mealType    MealType
  mealName    String
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId, mealDate])
  @@index([mealDate])
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model MealTemplate {
  id        String  @id @default(cuid())
  coachId   String?
  coach     User?   @relation(fields: [coachId], references: [id], onDelete: SetNull)
  mealName  String
  isCustom  Boolean @default(false)
  items     MealTemplateItem[]
  assignments Assignment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
}

model MealTemplateItem {
  id               String @id @default(cuid())
  mealTemplateId   String
  mealTemplate     MealTemplate @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  foodId           String
  food             Food @relation(fields: [foodId], references: [id])
  gramsDefault     Float

  @@index([mealTemplateId])
  @@index([foodId])
}

model Routine {
  id        String @id @default(cuid())
  clientId  String
  client    User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  routineDay String
  isAssigned Boolean @default(false)
  exercises Exercise[]
  assignments Assignment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Exercise {
  id        String @id @default(cuid())
  routineId String
  routine   Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exerciseName String
  sets         Int?
  reps         Int?
  notes        String?
  isCompleted  Boolean @default(false)
  completedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([routineId])
}

model WeightLog {
  id        String @id @default(cuid())
  clientId  String
  client    User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  weight    Float
  unit      String @default("kg")
  loggedDate String
  createdAt DateTime @default(now())

  @@index([clientId, loggedDate])
}

model ProgressPhoto {
  id        String @id @default(cuid())
  clientId  String
  client    User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  photoUrl  String
  caption   String?
  uploadedAt DateTime @default(now())

  @@index([clientId])
}

model ClientSubscription {
  id        String @id @default(cuid())
  coachId   String
  coach     User   @relation("CoachSubscriptions", fields: [coachId], references: [id], onDelete: Cascade)
  clientId  String
  client    User   @relation("ClientSubscriptions", fields: [clientId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan
  price     Float
  isActive  Boolean @default(true)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId, clientId])
  @@index([clientId])
}

enum SubscriptionPlan {
  BASIC
  PREMIUM
  ELITE
}

model Assignment {
  id             String @id @default(cuid())
  coachId        String
  coach          User @relation("CoachAssignments", fields: [coachId], references: [id], onDelete: Cascade)
  clientId       String
  client         User @relation("ClientAssignments", fields: [clientId], references: [id], onDelete: Cascade)
  assignmentType AssignmentType
  targetId       String
  mealTemplate   MealTemplate? @relation(fields: [targetId], references: [id], onDelete: SetNull)
  routine        Routine? @relation(fields: [targetId], references: [id], onDelete: SetNull)
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  createdAt      DateTime @default(now())

  @@index([coachId, clientId])
  @@index([clientId])
}

enum AssignmentType {
  DIET_TEMPLATE
  ROUTINE
}

model ChangeRequest {
  id           String @id @default(cuid())
  clientId     String
  client       User @relation("ClientChangeRequests", fields: [clientId], references: [id], onDelete: Cascade)
  coachId      String
  coach        User @relation("CoachChangeRequests", fields: [coachId], references: [id], onDelete: Cascade)
  requestType  RequestType
  description  String
  status       RequestStatus @default(PENDING)
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId, status])
}

enum RequestType {
  MEAL_SWAP
  ROUTINE_CHANGE
  GOAL_ADJUST
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
